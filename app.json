{
  "expo": {
    "name": "SimpleDo",
    "slug": "SimpleDo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.simpledo.app"
    },
    "android": {
      "package": "com.simpledo.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "SimpleDo нужен микрофон для голосового ввода списка.",
          "speechRecognitionPermission": "SimpleDo использует распознавание речи для добавления пунктов."
        }
      ]
    ]
  }
}
